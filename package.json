{
  "name": "rist",
  "version": "0.1.3",
  "private": true,
  "description": "A quiet cross-platform Redis desktop client.",
  "author": "la3rence",
  "packageManager": "pnpm@11.1.2",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "postinstall": "npx install-electron",
    "typecheck": "tsc --noEmit",
    "build": "electron-vite build",
    "pack:mac": "uv run --managed-python --no-project electron-builder --mac --publish=never",
    "dist:mac": "pnpm build && pnpm pack:mac",
    "publish:mac": "pnpm build && uv run --managed-python --no-project electron-builder --mac --publish=always",
    "dist:win": "pnpm build && electron-builder --win --publish=never",
    "publish:win": "pnpm build && electron-builder --win --publish=always",
    "preview": "electron-vite preview"
  },
  "build": {
    "appId": "app.rist.desktop",
    "productName": "Rist",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "la3rence",
        "repo": "rist",
        "releaseType": "release"
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.9",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
